[Unit]
Description=Ultimate Terminal Nexus Server
Documentation=https://github.com/stevenvo780/ultimate-terminal
After=network-online.target docker.service
Wants=network-online.target docker.service
# PostgreSQL puede tardar más que Nexus después de un reinicio del host. No
# agotar los reintentos mientras la base de datos termina de levantar.
StartLimitIntervalSec=0

[Service]
Type=simple
User=utnexus
Group=utnexus
EnvironmentFile=/etc/ultimate-terminal/nexus.env
ExecStart=/usr/bin/ultimate-terminal-nexus
WorkingDirectory=/var/lib/ultimate-terminal
Restart=always
RestartSec=10

# Security hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
RestrictRealtime=true
ReadWritePaths=/var/lib/ultimate-terminal

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=ut-nexus

[Install]
WantedBy=multi-user.target
